# Copy to .env — never commit .env to git.

# Gemini API key (optional — for AI summaries)
VITE_AI_API_KEY=

# Required for phone QR scanning on local network (localhost does NOT work on phones)
# Run: npm run dev -- --host
# Use YOUR PC's IPv4 from ipconfig (Wi-Fi)
VITE_PUBLIC_URL=http://192.168.0.0:5174

# Firebase (optional — app uses local seed data when any value is missing)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

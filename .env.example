# Copy to .env — never commit .env to git.

# Gemini API key (optional — for AI summaries)
VITE_AI_API_KEY=

# Required for phone QR scanning on local network (localhost does NOT work on phones)
# Run: npm run dev -- --host
# Use YOUR PC's IPv4 from ipconfig (Wi-Fi)
VITE_PUBLIC_URL=http://192.168.29.142:5174

# Demo seed data (default: false — public UI shows only admin-published records)
# Set to true only for local development with sample Itahari projects
VITE_USE_DEMO_SEED=false

# Firebase (optional — app uses empty local data when any value is missing)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — enable /dev-reset page in preview/production builds (default: dev only)
# VITE_ENABLE_DEV_RESET=true
